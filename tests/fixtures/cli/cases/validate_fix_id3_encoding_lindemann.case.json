{
  "description": "Validate id3-encoding --fix rewrites Lindemann MP3 text frames as UTF-16 and records undoable history",
  "expectations": {
    "initial-state": [
      {
        "path": "input/Lindemann - Ich Weiß Es Nicht.mp3",
        "tags": { "TrackTitle": "Ich Weiß Es Nicht" },
        "tag-encodings": { "TrackTitle": "UTF8" }
      }
    ],
    "fixed": [
      {
        "path": "input/Lindemann - Ich Weiß Es Nicht.mp3",
        "tags": { "TrackTitle": "Ich Weiß Es Nicht" },
        "tag-encodings": { "TrackTitle": "UTF16" }
      }
    ]
  },
  "tests": {
    "initial": {
      "expectations": "initial-state"
    },
    "check-id3-encoding": {
      "command": "--simple validate -i input id3-encoding",
      "expected-exit-code": 1,
      "expectations": "initial-state"
    },
    "fix-id3-encoding": {
      "command": "--simple --yes validate -i input id3-encoding --fix",
      "expectations": "fixed"
    },
    "undo": {
      "command": "--simple --yes undo",
      "expectations": "initial-state"
    },
    "redo": {
      "command": "--simple --yes redo",
      "expectations": "fixed"
    }
  }
}
