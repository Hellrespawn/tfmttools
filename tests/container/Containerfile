FROM rust:1.89-bookworm AS builder

WORKDIR /workspace
COPY . .

RUN cargo build --package tfmttools-cli --bin tfmt \
    && cargo build \
        --package tfmttools-test-container \
        --bin tfmt-container-verify

FROM debian:bookworm-slim AS runtime

RUN apt-get update \
    && apt-get install --yes --no-install-recommends \
        ca-certificates \
        coreutils \
        findutils \
        passwd \
        util-linux \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd --gid 1000 app \
    && useradd \
        --uid 1000 \
        --gid 1000 \
        --create-home \
        --shell /usr/sbin/nologin \
        app

COPY --from=builder /workspace/target/debug/tfmt /usr/local/bin/tfmt
COPY --from=builder \
    /workspace/target/debug/tfmt-container-verify \
    /usr/local/bin/tfmt-container-verify

WORKDIR /work
USER 1000:1000

ENTRYPOINT ["/usr/local/bin/tfmt"]
