# Maintainer: Stef Korporaal <stef@skorporaal.com>

prgname=tfmt
pkgname=tfmt
pkgver=${TFMT_PKGVER:-0.24.0}
pkgrel=1
pkgdesc='Use minijinja to rename audio files according to their tags.'
url='https://github.com/Hellrespawn/tfmttools'
license=('BSD-3-Clause')
depends=()
arch=('x86_64')
options=('!debug')
_target=x86_64-unknown-linux-gnu
_pkgbase=$prgname-$pkgver-$_target
source=("$_pkgbase.tar.gz")
sha256sums=('SKIP')

package() {
    install -Dm0755 "$srcdir/$_pkgbase/$prgname" "$pkgdir/usr/bin/$prgname"
    install -Dm0644 "$srcdir/$_pkgbase/LICENSE" \
        "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm0644 "$srcdir/$_pkgbase/README.md" \
        "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm0644 "$srcdir/$_pkgbase/CHANGELOG.md" \
        "$pkgdir/usr/share/doc/$pkgname/CHANGELOG.md"
    cp -R "$srcdir/$_pkgbase/examples" "$pkgdir/usr/share/doc/$pkgname/"

    install -Dm0644 "$srcdir/$_pkgbase/completions/tfmt.bash" \
        "$pkgdir/usr/share/bash-completion/completions/tfmt"
    install -Dm0644 "$srcdir/$_pkgbase/completions/_tfmt" \
        "$pkgdir/usr/share/zsh/site-functions/_tfmt"
    install -Dm0644 "$srcdir/$_pkgbase/completions/_tfmt.ps1" \
        "$pkgdir/usr/share/powershell/Completions/_tfmt.ps1"
    install -Dm0644 -t "$pkgdir/usr/share/man/man1/" \
        "$srcdir/$_pkgbase"/man/*.1
}
